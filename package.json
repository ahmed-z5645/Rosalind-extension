{
  "name": "rosalind-extension",
  "displayName": "Rosalind",
  "description": "Solve Rosalind.info computational biology problems from VS Code.",
  "version": "0.1.0",
  "publisher": "ahmed",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rosalind",
          "title": "Rosalind",
          "icon": "resources/dna.svg"
        }
      ]
    },
    "views": {
      "rosalind": [
        {
          "id": "rosalind.actions",
          "name": "Rosalind"
        }
      ]
    },
    "commands": [
      {
        "command": "rosalind.signIn",
        "title": "Rosalind: Sign In with Browser"
      },
      {
        "command": "rosalind.signOut",
        "title": "Rosalind: Sign Out"
      },
      {
        "command": "rosalind.createAccount",
        "title": "Rosalind: Create Account"
      },
      {
        "command": "rosalind.openProblem",
        "title": "Rosalind: Open Problem"
      },
      {
        "command": "rosalind.startTimer",
        "title": "Rosalind: Start Dataset Timer"
      },
      {
        "command": "rosalind.submitSolution",
        "title": "Rosalind: Submit Solution"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "axios-cookiejar-support": "^5.0.5",
    "cheerio": "^1.0.0",
    "sql.js": "^1.11.0",
    "tough-cookie": "^5.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "@types/turndown": "^5.0.5",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
